FT_APP_NAME=Field Translator
FT_ENVIRONMENT=dev
FT_DB_PATH=field_translator.db

# mock | openai
FT_PROVIDER=mock

# OpenAI only
FT_OPENAI_API_KEY=
FT_OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
FT_OPENAI_TRANSLATE_MODEL=gpt-4.1-mini

FT_MAX_CONTEXT_LINES=4
FT_SEGMENT_TIMEOUT_SECONDS=45
FT_CORS_ALLOW_ORIGINS=*